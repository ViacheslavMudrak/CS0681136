# See https://help.github.com/ignore-files/ for more about ignoring files.

# dependencies
/node_modules

# Lock files
package-lock.json

# next.js
/.next*/
/out/

# vitest coverage (HTML, JSON, COVERAGE-REPORT.md — all local-only)
coverage/

# misc
.DS_Store

# Storybook static export (local / CI artifact)
storybook-static/

# local documentation (not committed)
/docs/*

# local env files
.env.local
.env.*.local
.env

# Log files
*.log*

# vercel
.vercel

# sitecore temp files
.sitecore/*
# except for component-map
!.sitecore/component-map.ts
!.sitecore/component-map.client.ts
!.sitecore/import-map.ts

*storybook.log
