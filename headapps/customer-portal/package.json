    "@sitecore-cloudsdk/personalize": "0.6.1",
    "@sitecore-cloudsdk/search": "0.6.1",
    "@sitecore-content-sdk/nextjs": "~1.3.2",
    "@sitecore-feaas/clientside": "0.6.4",
    "jwt-decode": "^4.0.0",
    "next": "15.5.18",
    "next-intl": "4.3.5",
    "react": "19.2.1",
    "react-aria-components": "1.13.0",
    "react-dom": "19.2.1",
    "react-router-dom": "7.13.0",
    "rsc-env": "0.0.2",
    "tailwind-bootstrap-grid": "6.0.0"
  },
  "overrides": {
    "@sitecore-content-sdk/cli": "~1.3.2",
    "@sitecore-content-sdk/core": "~1.3.2",
    "@sitecore-content-sdk/react": "~1.3.2",
    "next": "15.5.18",
    "brace-expansion": "5.0.5",
    "underscore": "1.13.8",
    "@eslint/config-array": "0.23.2",
    "@rjsf/utils": "6.3.1",
    "@eslint/eslintrc": "3.3.4",
    "flatted": "3.4.2",
    "@typescript-eslint/parser": "8.56.1",
    "@typescript-eslint/project-service": "8.56.1",
    "@typescript-eslint/visitor-keys": "8.56.1",
    "@typescript-eslint/scope-manager": "8.56.1",
    "@typescript-eslint/utils": "8.56.1",
    "@typescript-eslint/types": "8.56.1",
    "@typescript-eslint/type-utils": "8.56.1",
    "@typescript-eslint/typescript-estree": "8.56.1",
    "@typescript-eslint/tsconfig-utils": "8.56.1",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@eslint/object-schema": "3.0.2",
    "es-iterator-helpers": "1.2.2",
    "@emnapi/wasi-threads": "1.1.0",
    "electron-to-chromium": "1.5.307",
    "@emnapi/runtime": "1.8.1",
    "caniuse-lite": "1.0.30001777",
    "@emnapi/core": "1.8.1",
    "ajv": "8.18.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.4",
    "@sitecore-content-sdk/cli": "~1.3.2",
    "@tailwindcss/postcss": "4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.15.14",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "@vitest/ui": "2.1.8",
    "cross-env": "10.0.0",
    "eslint": "9.33.0",
    "eslint-config-next": "15.5.0",
    "husky": "9.1.7",
    "jsdom": "25.0.1",
    "lint-staged": "16.2.6",
    "npm-run-all2": "8.0.4",
    "prettier": "3.6.2",
    "sass": "1.83.0",
    "tailwindcss": "4",
    "typescript": "~5.8.3",
    "vitest": "2.1.9"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production npm-run-all --serial sitecore-tools:generate-map sitecore-tools:build next:build",
    "lint": "eslint ./src/**/*.tsx ./src/**/*.ts",
    "lint:fix": "eslint ./src/**/*.tsx ./src/**/*.ts --fix",
    "next:build": "next build",
    "next:dev": "cross-env NODE_OPTIONS='--inspect' next dev",
    "next:start": "next start",
    "sitecore-tools:generate-map": "sitecore-tools project component generate-map",
    "sitecore-tools:generate-map:watch": "sitecore-tools project component generate-map --watch",
    "sitecore-tools:build": "sitecore-tools project build",
    "dev": "cross-env NODE_ENV=development npm-run-all --serial sitecore-tools:generate-map sitecore-tools:build --parallel next:dev sitecore-tools:generate-map:watch",
    "start": "cross-env-shell NODE_ENV=production npm-run-all --serial build next:start",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,scss,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,scss,json,md,yml,yaml}\"",
    "type-check": "tsc --noEmit",
    "quality-check": "npm run lint && npm run format:check && npm run type-check && npm run test",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vitest",
    "test:ui": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vitest --ui",
    "test:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vitest run --coverage"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  }
}
