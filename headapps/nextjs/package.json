  "scripts": {
    "build": "cross-env NODE_ENV=production NEXT_PUBLIC_NODE_ENV=production npm-run-all --serial sitecore-tools:generate-map sitecore-tools:build next:build",
    "lint": "eslint ./src/**/*.tsx ./src/**/*.ts",
    "tsCheck": "tsc --noEmit",
    "lintAll": "npm run lint && npm run tsCheck",
    "next:build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build --webpack",
    "next:dev": "cross-env NODE_OPTIONS='--inspect' next dev --webpack",
    "next:start": "next start",
    "sitecore-tools:generate-map": "sitecore-tools project component generate-map",
    "sitecore-tools:generate-map:watch": "sitecore-tools project component generate-map --watch",
    "sitecore-tools:build": "sitecore-tools project build",
    "dev": "cross-env NODE_ENV=development NEXT_PUBLIC_NODE_ENV=development NEXT_PUBLIC_ENV=LOCAL npm-run-all --serial sitecore-tools:generate-map sitecore-tools:build --parallel next:dev sitecore-tools:generate-map:watch",
    "start": "cross-env-shell NODE_ENV=production NEXT_PUBLIC_NODE_ENV=production npm-run-all --serial build next:start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "plop": "plop"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
