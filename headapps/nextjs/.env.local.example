# =============================================================================
# Environment Variables Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# .env.local is git-ignored and should never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------

# Enable static path generation during build
GENERATE_STATIC_PATHS=false

# Next.js base URL (required for NextAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sitecore Configuration
# -----------------------------------------------------------------------------
# Sitecore Edge Context ID (required for Edge API)
NEXT_PUBLIC_SITECORE_EDGE_CONTEXT_ID=
NEXT_PUBLIC_DEFAULT_SITE_NAME=
SITECORE_EDITING_SECRET=

# Sitecore Search Configuration
NEXT_PUBLIC_SITECORE_SEARCH_CUSTOMER_KEY=
NEXT_PUBLIC_SITECORE_SEARCH_API_KEY=

# -----------------------------------------------------------------------------
# Authentication (NextAuth)
# -----------------------------------------------------------------------------
# NextAuth Secret (required - generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
FORCE_AUTH=false

# -----------------------------------------------------------------------------
# Azure AD / Microsoft Entra ID Configuration
# -----------------------------------------------------------------------------
# Azure AD App Registration details
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Alternative Azure AD variable names (for compatibility)
# AUTH_MICROSOFT_ENTRA_ID_ID=
# AUTH_MICROSOFT_ENTRA_ID_SECRET=
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# -----------------------------------------------------------------------------
# Mock Authentication (Development Only)
# -----------------------------------------------------------------------------
# Enable mock authentication provider in development
NEXT_PUBLIC_ENABLE_MOCK_AUTH=true
ENABLE_MOCK_AUTH=true

# Mock user details (optional overrides)
MOCK_USER_EMAIL=mock.user@example.com
MOCK_USER_NAME=Mickey Mock
MOCK_USER_ID=f97yfsef-282g-ds05-2hdn-dakwlv92s8kg
MOCK_USER_DEPARTMENT=Engineering
MOCK_USER_COMPANY=Ascension
MOCK_USER_JOB_TITLE=Developer
MOCK_USER_COMPANY_CODE=ASC
MOCK_USER_BUSINESS_UNIT=66008

# -----------------------------------------------------------------------------
# Google Workspace
# -----------------------------------------------------------------------------
# Google OAuth2 Client Credentials details
GOOGLE_CLIENT_ID="148113766333-evt4lf9dlr52pd5gga79nnv6a9b5r2fq.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="RETRIEVE_FROM_KEY_VAULT"
# Google Service Account details
GOOGLE_IMPERSONATE_ADMIN_EMAIL="sitecore_sa@ascension.org"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CUSTOMER_ID=
# Groups API provider: 'cloud' (Cloud Identity, transitive) or 'admin' (Directory API, direct only). Defaults to 'cloud'.
GOOGLE_GROUPS_PROVIDER=

# -----------------------------------------------------------------------------
# SMTP Configuration (Email Sending)
# -----------------------------------------------------------------------------
# SMTP relay for outbound emails (join-request notifications, etc.)
# Ascension internal relay: mta.ascensionhealth.org (port 25, plaintext, no auth)
SMTP_HOST=mta.ascensionhealth.org
SMTP_PORT=25
SMTP_FROM_ADDRESS=ourascension-noreply@ascension.org
# Optional — only needed if the relay requires authentication:
# SMTP_USER=
# SMTP_PASSWORD=
# Skip STARTTLS auto-upgrade. Required for the Ascension relay on port 25 since
# it advertises STARTTLS but presents an expired cert. Stay plaintext on the
# internal network instead.
SMTP_IGNORE_TLS=true

# -----------------------------------------------------------------------------
# UKG (Kronos) Configuration
# -----------------------------------------------------------------------------
# UKG API credentials (server-side only — never prefix with NEXT_PUBLIC_)
UKG_USERNAME=APIUSERDFD
UKG_PASSWORD=RETRIEVE_FROM_KEY_VAULT
UKG_CLIENT_ID=6JxXWgTpAgPiXI31dgPuCO8jUThhSNXw
UKG_CLIENT_SECRET=RETRIEVE_FROM_KEY_VAULT

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Redis connection URL. Controls which Redis strategy is used:
#   - Not set          → ioredis-mock (in-memory, no Docker needed)
#   - Local Docker     → redis://localhost:6379  (run `npm run start:redis` from /emulators)
#   - Remote (GKE)     → redis://<host>:<port>   (set by deployment pipeline)
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Firebase / Firestore Configuration
# -----------------------------------------------------------------------------
# Firebase Emulator Configuration (Development)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=localhost
NEXT_PUBLIC_FIREBASE_EMULATOR_PORT=8081

# -----------------------------------------------------------------------------
# Oracle Cloud (HCM / Fusion) Configuration
# -----------------------------------------------------------------------------
# OAuth2 Client Credentials for Oracle Identity Cloud Service (IDCS)
ORACLE_TOKEN_URL=https://idcs-7b8396bd33164d1f854ab2793035216d.identity.oraclecloud.com/oauth2/v1/token
ORACLE_CLIENT_ID=5ef83b31e1d443098f7bc0302b2116f3
ORACLE_CLIENT_SECRET=RETRIEVE_FROM_KEY_VAULT
ORACLE_SCOPE=https://ibpcjb-dev1.fa.ocs.oraclecloud.com:443/
ORACLE_OAUTH_API_BASE_URL=https://ibpcjb-dev1.fa.ocs.oraclecloud.com:443
ORACLE_CLIENT_THUMBPRINT=9-CokURJ3Z02ot5shPI3T61Dnps
ORACLE_PRIVATE_KEY=RETRIEVE_FROM_KEY_VAULT



# =============================================================================
# Notes:
# =============================================================================
# 1. NEXT_PUBLIC_* variables are exposed to the browser and should not contain
#    sensitive information.
#
# 2. For production deployments:
#    - Use secure secret management (e.g., Kubernetes secrets, Azure Key Vault)
#    - Never commit .env.local or .env files
#    - Rotate secrets regularly
#
# 3. For Firebase in production (GKE):
#    - Service accounts are automatically used, no GOOGLE_APPLICATION_CREDENTIALS needed
#    - Ensure the service account has Firestore permissions
#
# 4. For local development with Firebase:
#    - Start the Firebase emulator: firebase emulators:start --only firestore
#    - The app will automatically connect to the emulator when USE_FIREBASE_EMULATOR=true
#
# 5. Mock Authentication:
#    - Only available in development mode
#    - Set NEXT_PUBLIC_ENABLE_MOCK_AUTH=true to enable
#    - Useful for testing without Azure AD setup
#
# 6. Sitecore Configuration:
#    - SITECORE_EDGE_CONTEXT_ID is required for Edge API access
#    - SITECORE_EDITING_SECRET is required for Sitecore editing mode
#    - NEXT_PUBLIC_SITECORE_API_KEY and NEXT_PUBLIC_SITECORE_API_HOST are for local development
#
# =============================================================================

